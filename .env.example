# Anthropic 兼容 API 配置
# 将本文件复制为 .env 并填入真实值
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://opencode.ai/go

# Planner Agent 模型配置
PLANNER_MODEL=DeepSeek V4 Flash
PLANNER_TEMPERATURE=0.3
PLANNER_MAX_TOKENS=2048

# Search Agent 配置
SEARCH_MAX_RESULTS=5
SEARCH_DEEP_SEARCH=true
SEARCH_MAX_ROUNDS=3

# Summary Agent 配置
SUMMARY_TEMPERATURE=0.3
SUMMARY_MAX_TOKENS=4096
SUMMARY_PERSIST_DIR=./data

# Write Agent 配置
WRITE_TEMPERATURE=0.3
WRITE_MAX_TOKENS=4096
WRITE_OUTPUT_DIR=./reports

# FastAPI 后端配置
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
DATABASE_URL=sqlite:///./research.db
MAX_CONCURRENT_PER_USER=2
MAX_CONCURRENT_TOTAL=10

# RAG Agent 配置
RAG_EMBED_MODEL=BAAI/bge-small-zh-v1.5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=100
RAG_TOP_K=5
RAG_DOC_SUMMARY_TOKENS=600
